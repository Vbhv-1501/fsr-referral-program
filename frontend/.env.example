# ─── API ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ─── Telegram ────────────────────────────────────────────────
# Your bot's username (without @), used for the login widget
NEXT_PUBLIC_BOT_NAME=YourBotUsername

# ─── Admin ───────────────────────────────────────────────────
# Comma-separated Telegram IDs granted admin access in frontend
NEXT_PUBLIC_ADMIN_TELEGRAM_IDS=123456789,987654321

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
